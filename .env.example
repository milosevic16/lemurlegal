# Copy to .env.local and fill in. Create the tokens in Contentful:
# Settings → API keys → "Content delivery / preview tokens".
#
# The CDA token is read-only and is inlined into the built client bundle — this
# is how Contentful client-side reads work and is safe. Never use a Content
# Management (CMA) token here.
VITE_CONTENTFUL_SPACE_ID=your_space_id
VITE_CONTENTFUL_ENVIRONMENT=master
VITE_CONTENTFUL_CDA_TOKEN=your_content_delivery_api_token

# Optional — only if you wire a draft/preview mode later.
# VITE_CONTENTFUL_PREVIEW_TOKEN=your_content_preview_api_token
