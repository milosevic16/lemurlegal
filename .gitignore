# Local env files — keep the Contentful token out of source control.
.env
.env.local
.env.*.local

# Generated by `vue-tsc -b` from vite.config.ts. vite.config.js MUST never be
# committed — Vite resolves it before vite.config.ts and would shadow config edits.
vite.config.js
vite.config.d.ts
*.tsbuildinfo

# Build output — Netlify compiles it fresh from src/ on every deploy (netlify.toml).
# Keeping it out of git stops the ~30-file SSG output from burying real diffs.
dist/
